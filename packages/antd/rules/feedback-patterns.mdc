## 空态设计规范

**每一个列表、表格、搜索结果都必须设计空态。**

```tsx
// 首次使用（无数据引导）
<Empty
  image={Empty.PRESENTED_IMAGE_SIMPLE}
  description={
    <span>
      还没有任何数据，<a>立即创建</a>
    </span>
  }
>
  <Button type="primary" icon={<PlusOutlined />} onClick={handleCreate}>
    创建第一条记录
  </Button>
</Empty>

// 搜索无结果
<Empty
  image={Empty.PRESENTED_IMAGE_SIMPLE}
  description="没有找到匹配的结果"
>
  <Button onClick={clearFilters}>清除筛选条件</Button>
</Empty>

// 权限不足
<Result
  status="403"
  title="无权访问"
  subTitle="您没有权限查看此页面"
  extra={<Button type="primary" onClick={() => navigate('/')}>返回首页</Button>}
/>
```

---

## 结果页规范

```tsx
// 操作成功结果页
<Result
  status="success"
  title="提交成功"
  subTitle="您的申请已提交，预计 1-3 个工作日内处理"
  extra={[
    <Button type="primary" key="home" onClick={() => navigate('/')}>
      返回首页
    </Button>,
    <Button key="view" onClick={() => navigate('/applications')}>
      查看进度
    </Button>,
  ]}
/>

// 404 / 500 错误页
<Result
  status="404"        // 或 "500" / "403" / "warning"
  title="404"
  subTitle="抱歉，您访问的页面不存在"
  extra={<Button type="primary" onClick={() => navigate(-1)}>返回上页</Button>}
/>
```

